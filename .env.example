# cTrader Trading Bot Environment Variables
# Copy this file to .env and fill in your credentials
# DO NOT commit .env file to version control!

# Required: Your cTrader account credentials
CTRADER_USERNAME=5179095
CTRADER_PASSWORD_QUOTE=your_quote_password_here
CTRADER_PASSWORD_TRADE=your_trade_password_here

# Optional: Configuration file paths (defaults shown)
CTRADER_CFG_QUOTE=config/ctrader_quote.cfg
CTRADER_CFG_TRADE=config/ctrader_trade.cfg

# Optional: Trading parameters
CTRADER_BTC_SYMBOL_ID=10028
CTRADER_QTY=0.10

# Optional: Logging
PY_LOGDIR=logs/python

# Optional: DDQN Model (leave empty to use fallback strategy)
DDQN_MODEL_PATH=
