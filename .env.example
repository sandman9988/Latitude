# cTrader Bot Environment Configuration
# Copy this file to .env and fill in your credentials
# DO NOT commit .env to version control!

# === cTrader Credentials (REQUIRED) ===
CTRADER_USERNAME=5179095
CTRADER_PASSWORD_QUOTE=your_quote_password_here
CTRADER_PASSWORD_TRADE=your_trade_password_here

# === Trading Configuration (REQUIRED) ===
SYMBOL=XAUUSD
SYMBOL_ID=41
QTY=0.01
TIMEFRAME_MINUTES=1

# === FIX Configuration Files ===
CTRADER_CFG_QUOTE=config/ctrader_quote.cfg
CTRADER_CFG_TRADE=config/ctrader_trade.cfg

# === Trading Mode ===
# Set PAPER_MODE=1 for training with no gates, 0 for live trading
PAPER_MODE=1

# === Training Parameters (for PAPER_MODE=1) ===
DISABLE_GATES=1
FEAS_THRESHOLD=0.0
EPSILON_START=1.0
EPSILON_END=0.1
EPSILON_DECAY=0.9995
EXPLORATION_BOOST=0.5
MAX_BARS_INACTIVE=10
FORCE_EXPLORATION=1

# === Live Trading Parameters (for PAPER_MODE=0) ===
# Uncomment and use these when switching to live mode:
# DISABLE_GATES=0
# FEAS_THRESHOLD=0.5
# CONFIDENCE_FLOOR=0.55
# EPSILON_START=0.05
# EPSILON_END=0.01
# EPSILON_DECAY=0.9995
# EXPLORATION_BOOST=0.0
# MAX_BARS_INACTIVE=1000
# FORCE_EXPLORATION=0

# === Online Learning ===
DDQN_ONLINE_LEARNING=1

# === Optional: Risk and Circuit Breakers ===
# CTRADER_DEPTH_LEVELS=5
# CTRADER_DEPTH_BUFFER=2.0
# CTRADER_SPREAD_RELAX=3.0
# CTRADER_VPIN_Z_LIMIT=2.5
# CTRADER_VOL_REF=0.005
# CTRADER_VOL_CAP=0.05
# CTRADER_RISK_BUDGET_USD=50.0
# CTRADER_KURTOSIS_THRESHOLD=3.0
