# ============================================================================
# Latitude cTrader Open API — Environment Configuration
# ============================================================================
# Usage:
#   cp .env.openapi.example .env.openapi
#   python -m ctrader.auth          # instructions + browser launch
#   python run_backtest.py --symbol XAUUSD --days 360
# ============================================================================

# --- OAuth2 Application Credentials (from openapi.ctrader.com) --------------
CTRADER_CLIENT_ID=""
CTRADER_CLIENT_SECRET=""
CTRADER_REDIRECT_URI="http://127.0.0.1:8787/callback"
CTRADER_SCOPE="trading"

# --- Access Token (obtain via: python -m ctrader.auth) ----------------------
CTRADER_ACCESS_TOKEN=""
CTRADER_REFRESH_TOKEN=""   # optional; fill in to enable token refresh

# --- Account -----------------------------------------------------------------
CTRADER_ACCOUNT_ID=""
CTRADER_ENVIRONMENT="demo"   # "demo" or "live"

# --- DNS hardening -----------------------------------------------------------
# Restrict resolved IP fallbacks to trusted broker API domains.
LATITUDE_DNS_ALLOW_SUFFIXES="ctraderapi.com,spotware.com"
LATITUDE_DNS_MIN_UNIQUE_IPS="1"
LATITUDE_DNS_BLOCK_PRIVATE="true"
LATITUDE_DNS_FAIL_CLOSED="true"
LATITUDE_DNS_RESOLVERS="1.1.1.1,1.0.0.1,8.8.8.8,8.8.4.4,9.9.9.9,149.112.112.112"
LATITUDE_DNS_QUERY_TIMEOUT_S="2.0"
LATITUDE_DNS_QUERY_LIFETIME_S="4.0"

# --- Endpoint redundancy -----------------------------------------------------
# Comma-separated hostnames/IPs probed before connect; fastest wins.
CTRADER_ALT_ENDPOINTS="15.197.239.248,3.33.208.221,live.ctraderapi.com,13.248.223.213,76.223.75.209"
# Resolve alt endpoint hostnames to IPs and add as extra fallbacks.
CTRADER_INCLUDE_RESOLVED_IP_FALLBACKS="true"
CTRADER_ENDPOINT_PROBE_TIMEOUT_S="2.0"
